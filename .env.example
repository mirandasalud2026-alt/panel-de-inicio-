# CONFIGURACIÓN DE SUPABASE (CRÍTICO)
# Importante: Las variables DEBEN comenzar con VITE_ para ser visibles en el navegador.
# Si usa Vercel o Docker, asegúrese de incluirlas así:
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# APP_URL: La URL de despliegue
APP_URL="https://tu-app.vercel.app"

# GOOGLE WORKSPACE (Sincronización)
GOOGLE_DRIVE_FOLDER_ID=
